{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users (teachers or parents)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["teacher", "parent"] },
        "studentIds": { "type": "array", "description": "For parents, IDs of their children" }
      },
      "required": ["userId", "name", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "rollNumber": { "type": "string" },
        "classId": { "type": "string" },
        "parentEmail": { "type": "string" }
      },
      "required": ["id", "name", "rollNumber", "classId"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance logs",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent"] },
        "classId": { "type": "string" }
      },
      "required": ["studentId", "date", "status", "classId"]
    },
    "Mark": {
      "title": "Mark",
      "description": "Academic performance logs",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "subject": { "type": "string" },
        "score": { "type": "number" },
        "maxScore": { "type": "number" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["studentId", "subject", "score", "maxScore", "date"]
    },
    "Note": {
      "title": "Note",
      "description": "Learning materials and class links",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["note", "class_link"] },
        "url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["classId", "title", "content", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student registry"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records"
    },
    "/marks/{markId}": {
      "schema": "Mark",
      "description": "Marks records"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Class notes and links"
    }
  }
}
