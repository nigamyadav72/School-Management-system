rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Phase 3: Primitive Definition ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isTeacher() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'teacher';
    }
    
    function isParent() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'parent';
    }

    // --- Validation Helpers ---
    
    function isValidUser(data) {
      return data.userId == request.auth.uid 
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.role in ['teacher', 'parent']
        && (data.role == 'parent' ? (data.studentIds is list) : true);
    }

    function isValidStudent(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.rollNumber is string && data.rollNumber.size() > 0 && data.rollNumber.size() <= 20
        && data.classId is string && data.classId.size() > 0 && data.classId.size() <= 50;
    }

    function isValidAttendance(data) {
      return data.studentId is string && isValidId(data.studentId)
        && data.date is string // YYYY-MM-DD
        && data.status in ['present', 'absent']
        && data.classId is string && data.classId.size() > 0;
    }

    function isValidMark(data) {
      return data.studentId is string && isValidId(data.studentId)
        && data.subject is string && data.subject.size() > 0
        && data.score is number && data.score >= 0
        && data.maxScore is number && data.maxScore > 0
        && data.score <= data.maxScore
        && data.date is string;
    }

    function isValidNote(data) {
      return data.classId is string && data.classId.size() > 0
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.content is string && data.content.size() <= 10000
        && data.type in ['note', 'class_link']
        && (data.type == 'class_link' ? (data.url is string && data.url.size() > 0) : true)
        && data.createdAt == request.time;
    }

    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming())
        && incoming().role == existing().role; // Role is immutable
    }

    match /students/{studentId} {
      allow get: if isTeacher() || (isParent() && studentId in getUserData(request.auth.uid).studentIds);
      allow list: if isTeacher(); // Parents must get individual student docs
      allow create: if isTeacher() && isValidStudent(incoming());
      allow update: if isTeacher() && isValidStudent(incoming());
      allow delete: if isTeacher();
    }

    match /attendance/{attendanceId} {
      allow read: if isTeacher() || (isParent() && incoming().studentId in getUserData(request.auth.uid).studentIds);
      // Wait, incoming() is null for read! Fix:
      allow list: if isTeacher() || (isParent() && resource.data.studentId in getUserData(request.auth.uid).studentIds);
      allow get: if isTeacher() || (isParent() && resource.data.studentId in getUserData(request.auth.uid).studentIds);
      
      allow create: if isTeacher() && isValidAttendance(incoming())
        && exists(/databases/$(database)/documents/students/$(incoming().studentId));
      allow update: if isTeacher() && isValidAttendance(incoming());
      allow delete: if isTeacher();
    }

    match /marks/{markId} {
      allow list: if isTeacher() || (isParent() && resource.data.studentId in getUserData(request.auth.uid).studentIds);
      allow get: if isTeacher() || (isParent() && resource.data.studentId in getUserData(request.auth.uid).studentIds);
      
      allow create: if isTeacher() && isValidMark(incoming())
        && exists(/databases/$(database)/documents/students/$(incoming().studentId));
      allow update: if isTeacher() && isValidMark(incoming());
      allow delete: if isTeacher();
    }

    match /notes/{noteId} {
      allow read: if isTeacher() || isParent(); // Notes are school-wide or class-wide
      allow create: if isTeacher() && isValidNote(incoming());
      allow update: if isTeacher() && isValidNote(incoming());
      allow delete: if isTeacher();
    }
  }
}
